# Maintainer: stron <contact@stron.me>
pkgname=rustfy
pkgver=0.0.10
pkgrel=1
pkgdesc="App launcher and menu for Wayland compositors"
arch=("x86_64")
url="https://github.com/elstron/hybar"
license=("Apache-2.0")

depends=()
makedepends=(
  "rust"
  "cargo"
  "glib2"
  "meson"
  "ninja"
  "blueprint-compiler"
)

build() {
  cd "$startdir/.."

  # Build UI (.ui) from Blueprints and bundle resources via Meson
  meson setup --reconfigure --buildtype=release "$srcdir/builddir" .
  meson compile -C "$srcdir/builddir"

  cargo build --release
}

package() {
  cd "$startdir/.."
  install -Dm755 target/release/rustfy \
    "$pkgdir/usr/bin/rustfy"
  install -Dm644 "$srcdir/builddir/data/rustfy.gresource" \
    "$pkgdir/usr/share/rustfy/rustfy.gresource"
}
